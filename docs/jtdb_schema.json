      "name": "ISS",
      "name_en": "Injury Severity Score",
      "required": "*",
      "type": "calculated",
      "formula": "最大AIS上位3部位の二乗和。いずれかの部位でAIS=6の場合は自動的に75。",
      "constraints": { "min": 1, "max": 75 },
      "notes": "自動計算。AIS≥3で対象。"
